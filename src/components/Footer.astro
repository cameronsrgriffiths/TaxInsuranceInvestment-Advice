---
const base = import.meta.env.BASE_URL;
const link = (p = '') => (`${base}/${p}`).replace(/\/{2,}/g, '/');
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__name">Tax · Insurance · Investment Advice</p>
      <p class="site-footer__tag">Clear, independent financial guidance for individuals and businesses.</p>
    </div>
    <nav class="site-footer__nav">
      <a href={link('')}>Home</a>
      <a href={link('services')}>Services</a>
      <a href={link('about')}>About</a>
      <a href={link('contact')}>Contact</a>
    </nav>
  </div>
  <div class="container site-footer__legal">
    <p>
      &copy; {year} Tax · Insurance · Investment Advice. The information on this
      website is provided for general guidance only and does not constitute
      personal financial, tax, or legal advice. The value of investments can fall
      as well as rise and you may get back less than you invested. Please seek
      advice tailored to your circumstances before acting.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: rgba(255, 255, 255, 0.8);
    padding: 3rem 0 2rem;
    margin-top: 2rem;
  }
  .site-footer__inner {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  .site-footer__name { color: var(--white); font-weight: 700; margin: 0 0 0.25rem; }
  .site-footer__tag { margin: 0; font-size: 0.95rem; max-width: 42ch; }
  .site-footer__nav { display: flex; gap: 1.5rem; align-items: flex-start; flex-wrap: wrap; }
  .site-footer__nav a { color: rgba(255, 255, 255, 0.85); font-size: 0.95rem; }
  .site-footer__nav a:hover { color: var(--gold-light); }
  .site-footer__legal p {
    margin: 1.5rem 0 0;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    max-width: 80ch;
  }
</style>
