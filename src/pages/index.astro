---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const link = (p = '') => (`${base}/${p}`).replace(/\/{2,}/g, '/');

const services = [
  {
    title: 'Tax Planning',
    body: 'Reduce what you owe, stay compliant, and keep more of what you earn with proactive, year-round tax strategy.',
    icon: '%',
  },
  {
    title: 'Insurance',
    body: 'Protect your family and business with cover that fits — life, income protection, health, and key-person policies.',
    icon: '🛡',
  },
  {
    title: 'Investments',
    body: 'Build long-term wealth with a diversified, risk-appropriate portfolio aligned to your goals and timeline.',
    icon: '↗',
  },
];

const stats = [
  { value: '£250m+', label: 'Assets advised on' },
  { value: '1,200+', label: 'Clients guided' },
  { value: '20 yrs', label: 'Combined experience' },
  { value: 'Fee-only', label: 'Independent & unbiased' },
];
---

<Layout path="" title="Tax · Insurance · Investment Advice — Independent financial guidance">
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <p class="eyebrow">Independent · Fee-only · Personal</p>
        <h1>Smarter decisions about your tax, protection, and wealth.</h1>
        <p class="lead">
          We bring tax planning, insurance, and investments together into one clear
          strategy — so every part of your financial life is working in the same direction.
        </p>
        <div class="hero__actions">
          <a href={link('contact')} class="btn btn--primary">Book a free consultation</a>
          <a href={link('services')} class="btn btn--ghost">Explore our services</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--3">
        {services.map((s) => (
          <article class="card">
            <div class="card__icon">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--mist">
    <div class="container stats">
      {stats.map((s) => (
        <div class="stats__item">
          <span class="stats__value">{s.value}</span>
          <span class="stats__label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container cta">
      <h2>One conversation could change the shape of your finances.</h2>
      <p class="lead mx-auto">
        Whether you're planning for retirement, protecting a growing family, or
        navigating a tax decision, we'll give you a clear, honest view of your options.
      </p>
      <a href={link('contact')} class="btn btn--primary">Start the conversation</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background:
      radial-gradient(1200px 500px at 80% -10%, rgba(194, 161, 77, 0.18), transparent 60%),
      linear-gradient(160deg, var(--navy), var(--navy-light));
    color: var(--white);
    padding: 5.5rem 0 6rem;
  }
  .hero__content { max-width: 720px; }
  .hero h1 { color: var(--white); }
  .hero .lead { color: rgba(255, 255, 255, 0.82); }
  .hero__actions { display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap; }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .stats__item { display: flex; flex-direction: column; gap: 0.25rem; }
  .stats__value { font-size: 2rem; font-weight: 700; color: var(--navy); }
  .stats__label { font-size: 0.9rem; color: var(--slate); }

  .cta { text-align: center; max-width: 720px; }
  .cta .btn { margin-top: 1.5rem; }

  @media (max-width: 820px) {
    .stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>
