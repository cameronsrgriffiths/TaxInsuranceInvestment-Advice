---
import Layout from '../layouts/Layout.astro';
---

<Layout path="contact" title="Contact — Tax, Insurance & Investment Advice">
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">Get in touch</p>
      <h1>Let's talk about your goals.</h1>
      <p class="lead">
        Book a free, no-obligation consultation. Tell us a little about your
        situation and we'll come back to you within one working day.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <!--
        This form posts to Formspree (a free form backend that works on static
        hosts). Replace `your-form-id` below with your own endpoint from
        https://formspree.io — or swap the action for any other form service.
        Until then, the "Email us" link is a working fallback.
      -->
      <form class="contact-form" action="https://formspree.io/f/your-form-id" method="POST">
        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required placeholder="Your full name" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required placeholder="you@example.com" />
        </div>
        <div class="field">
          <label for="topic">I'd like help with</label>
          <select id="topic" name="topic">
            <option>Tax planning</option>
            <option>Insurance & protection</option>
            <option>Investments</option>
            <option>Retirement planning</option>
            <option>Something else</option>
          </select>
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" placeholder="Tell us a little about what you're looking for..."></textarea>
        </div>
        <button type="submit" class="btn btn--primary">Send message</button>
      </form>

      <aside class="contact-info">
        <h3>Other ways to reach us</h3>
        <p>
          <strong>Email</strong><br />
          <a href="mailto:hello@example.com">hello@example.com</a>
        </p>
        <p>
          <strong>Phone</strong><br />
          <a href="tel:+440000000000">+44 (0)00 0000 0000</a>
        </p>
        <p>
          <strong>Hours</strong><br />
          Monday–Friday, 9:00–17:30
        </p>
        <p class="contact-info__note">
          Prefer to talk first? Email or call and we'll arrange a time that suits you.
        </p>
      </aside>
    </div>
  </section>
</Layout>

<style>
  .page-head { padding: 4rem 0 1rem; }
  .contact-grid {
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 2.5rem; align-items: start;
  }
  .contact-form {
    background: var(--white); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 2rem; box-shadow: var(--shadow);
  }
  .field { margin-bottom: 1.25rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .field label { font-weight: 600; font-size: 0.9rem; color: var(--navy); }
  .field input, .field select, .field textarea {
    font-family: inherit; font-size: 0.97rem; color: var(--ink);
    padding: 0.7rem 0.85rem; border: 1px solid var(--line);
    border-radius: 8px; background: var(--mist);
  }
  .field input:focus, .field select:focus, .field textarea:focus {
    outline: none; border-color: var(--gold); background: var(--white);
  }
  .contact-info {
    background: var(--mist); border-radius: var(--radius); padding: 1.75rem;
  }
  .contact-info h3 { margin-bottom: 1rem; }
  .contact-info p { color: var(--slate); }
  .contact-info strong { color: var(--navy); }
  .contact-info__note { font-size: 0.9rem; margin-top: 1.5rem; }
  @media (max-width: 820px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
