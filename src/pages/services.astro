---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const link = (p = '') => (`${base}/${p}`).replace(/\/{2,}/g, '/');

const services = [
  {
    title: 'Tax Planning',
    summary: 'Keep more of what you earn, legally and confidently.',
    points: [
      'Personal & business income tax strategy',
      'Capital gains and dividend planning',
      'Pension and allowance optimisation',
      'Estate & inheritance tax mitigation',
    ],
  },
  {
    title: 'Insurance & Protection',
    summary: 'The right cover for the people and things that matter.',
    points: [
      'Life and critical illness cover',
      'Income protection',
      'Private medical insurance',
      'Business & key-person protection',
    ],
  },
  {
    title: 'Investments',
    summary: 'A disciplined, evidence-based approach to growing wealth.',
    points: [
      'Goal-based portfolio design',
      'ISA, pension & general investment accounts',
      'Risk profiling and rebalancing',
      'Ethical & ESG investment options',
    ],
  },
  {
    title: 'Retirement Planning',
    summary: 'Plan with confidence for the life you want later.',
    points: [
      'Retirement income modelling',
      'Pension consolidation reviews',
      'Drawdown vs annuity guidance',
      'Sustainable withdrawal strategies',
    ],
  },
];

const steps = [
  { n: '01', title: 'Discovery', body: 'A no-obligation conversation to understand your goals, finances, and concerns.' },
  { n: '02', title: 'Strategy', body: 'We build a clear, written plan covering tax, protection, and investments together.' },
  { n: '03', title: 'Implementation', body: 'We put the plan into action and handle the paperwork on your behalf.' },
  { n: '04', title: 'Review', body: 'Regular check-ins keep your plan on track as life and markets change.' },
];
---

<Layout path="services" title="Services — Tax, Insurance & Investment Advice">
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">What we do</p>
      <h1>Joined-up advice across your whole financial life.</h1>
      <p class="lead">
        Most people get tax, insurance, and investment advice from three different
        places that never talk to each other. We bring them together under one plan.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        {services.map((s) => (
          <article class="card service">
            <h3>{s.title}</h3>
            <p class="service__summary">{s.summary}</p>
            <ul class="service__list">
              {s.points.map((p) => <li>{p}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--mist">
    <div class="container">
      <p class="eyebrow center">How it works</p>
      <h2 class="center">A simple, four-step process</h2>
      <div class="grid grid--2 steps">
        {steps.map((s) => (
          <div class="step">
            <span class="step__n">{s.n}</span>
            <div>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="center" style="margin-top: 2.5rem;">
        <a href={link('contact')} class="btn btn--primary">Book your discovery call</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-head { padding: 4rem 0 1rem; }
  .service__summary { color: var(--navy); font-weight: 500; margin-bottom: 1rem; }
  .service__list { margin: 0; padding: 0; list-style: none; }
  .service__list li {
    position: relative; padding-left: 1.5rem; margin-bottom: 0.5rem;
    color: var(--slate); font-size: 0.97rem;
  }
  .service__list li::before {
    content: '✓'; position: absolute; left: 0; color: var(--gold); font-weight: 700;
  }
  .steps { margin-top: 2.5rem; }
  .step { display: flex; gap: 1rem; align-items: flex-start; }
  .step__n {
    font-size: 1.1rem; font-weight: 700; color: var(--gold);
    border: 2px solid var(--gold); border-radius: 8px;
    padding: 0.3rem 0.55rem; flex-shrink: 0;
  }
  .step h3 { margin-bottom: 0.2rem; }
  .step p { color: var(--slate); margin: 0; }
</style>
