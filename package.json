{
  "name": "insurance",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "npm run build && vite preview",
    "deploy": "npm run build && wrangler deploy",
    "typegen": "react-router typegen",
    "typecheck": "react-router typegen && tsc",
    "db:create": "wrangler d1 create insurance",
    "db:migrate": "wrangler d1 migrations apply insurance --remote",
    "db:migrate:local": "wrangler d1 migrations apply insurance --local"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.106.0",
    "isbot": "5.1.32",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-router": "7.9.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.15.3",
    "@cloudflare/workers-types": "^4.20250620.0",
    "@react-router/dev": "7.9.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3",
    "vite": "^7.0.0",
    "wrangler": "^4.20.0"
  }
}
